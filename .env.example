# Bailian / DashScope coding endpoint key (recommended now)
# Only set one provider key: BAILIAN_API_KEY or DASHSCOPE_API_KEY or OPENAI_API_KEY
BAILIAN_API_KEY=

# Optional for qwen provider:
DASHSCOPE_API_KEY=
# Optional override base URL:
# VIDEO_TO_ASSETS_LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# Optional: keep OPENAI_API_KEY if you want provider=openai
OPENAI_API_KEY=
VIDEO_TO_ASSETS_LOG_LEVEL=INFO
VIDEO_TO_ASSETS_USE_MOCK_LLM=false
